<launch>
  <node pkg="laser_filters" type="scan_to_scan_filter_chain" name="laser_filter" output="screen">
    <rosparam command="load" file="$(find redbot02_navigation)/config/lidar_filter.yaml" />
    <param name="input_scan_topic" value="/scan" />
    <param name="output_scan_topic" value="/scan_filtered" />
  </node>
</launch>